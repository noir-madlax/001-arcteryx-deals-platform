  "main": "expo-router/entry",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.1",
    "expo": "~57.0.4",
    "expo-blur": "~57.0.0",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-status-bar": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "~19.2.2",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "tsx --test __tests__/*.test.ts",
    "verify": "tsx scripts/verify-local.ts",
    "verify:config": "tsx scripts/verify-config.ts",
    "verify:live-data": "tsx scripts/verify-live-data.ts",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "eas:build:ios": "npx eas-cli build --platform ios --profile production",
    "eas:build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "eas:build:ios:simulator": "npx eas-cli build --platform ios --profile simulator",
    "eas:submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "private": true
}
