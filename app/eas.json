{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "local",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "medium"
      }
    },
    "simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "medium"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {}
    }
  }
}
