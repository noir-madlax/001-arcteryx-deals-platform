<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#0a0a0a">
    <title>Arc'teryx Outlet | 折扣专区</title>
    <link rel="preconnect" href="https://images-dynamic-arcteryx.imgix.net">
    <style>
        :root {
            --bg: #0a0a0a;
            --card: #141414;
            --card-hover: #1a1a1a;
            --border: #222;
            --text: #fff;
            --text2: #888;
            --accent: #00d2ff;
            --red: #ff4757;
            --green: #2ed573;
            --tag-bg: rgba(255,71,87,0.15);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro', 'Helvetica Neue', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding-bottom: env(safe-area-inset-bottom, 20px);
        }
        
        /* Header */
        .header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(10,10,10,0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 12px 16px;
        }
        .header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }
        .logo {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .logo span { color: var(--accent); }
        .stats {
            font-size: 12px;
            color: var(--text2);
        }
        
        /* Filter Tabs */
        .filter-row {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            scrollbar-width: none;
            -ms-overflow-style: none;
            padding-bottom: 4px;
        }
        .filter-row::-webkit-scrollbar { display: none; }
        .filter-tab {
            flex-shrink: 0;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            background: var(--card);
            border: 1px solid var(--border);
            color: var(--text2);
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }
        .filter-tab.active {
            background: var(--accent);
            color: #000;
            border-color: var(--accent);
            font-weight: 600;
        }
        .filter-tab .count {
            font-size: 11px;
            opacity: 0.7;
            margin-left: 4px;
        }
        
        /* Sort Bar */
        .sort-bar {
            display: flex;
            gap: 12px;
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
        }
        .sort-btn {
            font-size: 13px;
            color: var(--text2);
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .sort-btn.active { color: var(--accent); }
        .sort-btn .arrow { font-size: 10px; }
        
        /* Product Grid */
        .grid {
            padding: 12px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }
        
        /* Product Card */
        .card {
            background: var(--card);
            border-radius: 12px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.2s, background 0.2s;
            border: 1px solid var(--border);
        }
        .card:active {
            transform: scale(0.98);
            background: var(--card-hover);
        }
        .card-img {
            width: 100%;
            aspect-ratio: 3/4;
            object-fit: cover;
            background: #1a1a1a;
        }
        .card-body {
            padding: 10px;
        }
        .card-name {
            font-size: 13px;
            font-weight: 500;
            line-height: 1.3;
            margin-bottom: 6px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .card-price {
            display: flex;
            align-items: baseline;
            gap: 6px;
            margin-bottom: 6px;
        }
        .price-sale {
            font-size: 16px;
            font-weight: 700;
            color: var(--red);
        }
        .price-original {
            font-size: 12px;
            color: var(--text2);
            text-decoration: line-through;
        }
        .card-tags {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
        }
        .tag {
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            background: var(--tag-bg);
            color: var(--red);
            font-weight: 600;
        }
        .tag-region {
            background: rgba(0,210,255,0.1);
            color: var(--accent);
        }
        
        /* Detail Modal */
        .modal {
            position: fixed;
            inset: 0;
            z-index: 200;
            background: rgba(0,0,0,0.9);
            display: none;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .modal.show { display: flex; opacity: 1; }
        .modal-content {
            width: 100%;
            max-height: 100vh;
            overflow-y: auto;
            background: var(--bg);
            animation: slideUp 0.3s ease;
        }
        @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
        }
        .modal-img {
            width: 100%;
            aspect-ratio: 3/4;
            object-fit: cover;
        }
        .modal-close {
            position: fixed;
            top: 12px;
            right: 12px;
            z-index: 201;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(0,0,0,0.7);
            border: none;
            color: #fff;
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .modal-body {
            padding: 16px;
        }
        .modal-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }
        .modal-desc {
            font-size: 14px;
            color: var(--text2);
            line-height: 1.5;
            margin-bottom: 16px;
        }
        .modal-prices {
            display: flex;
            align-items: baseline;
            gap: 12px;
            margin-bottom: 16px;
        }
        .modal-price-sale {
            font-size: 28px;
            font-weight: 700;
            color: var(--red);
        }
        .modal-price-original {
            font-size: 16px;
            color: var(--text2);
            text-decoration: line-through;
        }
        .modal-discount {
            font-size: 14px;
            padding: 4px 10px;
            border-radius: 6px;
            background: var(--tag-bg);
            color: var(--red);
            font-weight: 600;
        }
        
        /* Size Grid */
        .section-title {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
            color: var(--text2);
        }
        .size-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin-bottom: 20px;
        }
        .size-item {
            padding: 10px;
            text-align: center;
            border-radius: 8px;
            background: var(--card);
            border: 1px solid var(--border);
            font-size: 14px;
        }
        .size-item.out {
            opacity: 0.3;
            text-decoration: line-through;
        }
        .size-item.in { border-color: var(--green); }
        
        /* Color Grid */
        .color-grid {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }
        .color-item {
            padding: 6px 12px;
            border-radius: 6px;
            background: var(--card);
            border: 1px solid var(--border);
            font-size: 12px;
        }
        
        /* CTA */
        .cta-btn {
            display: block;
            width: 100%;
            padding: 14px;
            border-radius: 12px;
            background: var(--accent);
            color: #000;
            font-size: 16px;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
            border: none;
            cursor: pointer;
        }
        
        /* Loading */
        .loading {
            text-align: center;
            padding: 40px;
            color: var(--text2);
        }
        .loading::after {
            content: '';
            display: block;
            width: 24px;
            height: 24px;
            margin: 12px auto;
            border: 2px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        /* Empty */
        .empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--text2);
        }
        .empty-icon { font-size: 48px; margin-bottom: 12px; }
        
        /* Region */
        .region-select {
            display: flex;
            gap: 6px;
            margin-top: 8px;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-top">
            <div class="logo">ARC'TERYX <span>OUTLET</span></div>
            <div class="stats" id="stats">加载中...</div>
        </div>
        <div class="filter-row" id="categories">
            <div class="filter-tab active" data-cat="all">全部</div>
        </div>
        <div class="filter-row region-select" id="regions">
            <div class="filter-tab active" data-region="all">全球</div>
        </div>
    </div>
    
    <div class="sort-bar">
        <button class="sort-btn active" data-sort="discount">
            折扣最高 <span class="arrow">↓</span>
        </button>
        <button class="sort-btn" data-sort="price-asc">
            价格↑
        </button>
        <button class="sort-btn" data-sort="price-desc">
            价格↓
        </button>
        <button class="sort-btn" data-sort="newest">
            最新
        </button>
    </div>
    
    <div class="grid" id="grid"></div>
    
    <!-- Detail Modal -->
    <div class="modal" id="modal">
        <button class="modal-close" onclick="closeModal()">×</button>
        <div class="modal-content" id="modal-content"></div>
    </div>

    <script src="../data.js"></script>
    <script>
        let currentCat = 'all';
        let currentRegion = 'all';
        let currentSort = 'discount';
        let filtered = [];
        
        // 统计
        const categories = {};
        const regions = {};
        PRODUCTS.forEach(p => {
            const cat = p.category || '其他';
            categories[cat] = (categories[cat] || 0) + 1;
            const reg = p.region_name || '未知';
            regions[reg] = (regions[reg] || 0) + 1;
        });
        
        // 初始化分类
        const catContainer = document.getElementById('categories');
        Object.entries(categories)
            .sort((a,b) => b[1] - a[1])
            .forEach(([cat, count]) => {
                const div = document.createElement('div');
                div.className = 'filter-tab';
                div.dataset.cat = cat;
                div.innerHTML = `${cat} <span class="count">${count}</span>`;
                catContainer.appendChild(div);
            });
        
        // 初始化地区
        const regContainer = document.getElementById('regions');
        Object.entries(regions)
            .sort((a,b) => b[1] - a[1])
            .forEach(([reg, count]) => {
                const div = document.createElement('div');
                div.className = 'filter-tab';
                div.dataset.region = reg;
                div.innerHTML = `${reg} <span class="count">${count}</span>`;
                regContainer.appendChild(div);
            });
        
        // 筛选逻辑
        function filterAndSort() {
            filtered = PRODUCTS.filter(p => {
                if (currentCat !== 'all' && p.category !== currentCat) return false;
                if (currentRegion !== 'all' && p.region_name !== currentRegion) return false;
                return true;
            });
            
            // 排序
            switch(currentSort) {
                case 'discount':
                    filtered.sort((a,b) => (b.discount_pct||0) - (a.discount_pct||0));
                    break;
                case 'price-asc':
                    filtered.sort((a,b) => (a.sale_price||9999) - (b.sale_price||9999));
                    break;
                case 'price-desc':
                    filtered.sort((a,b) => (b.sale_price||0) - (a.sale_price||0));
                    break;
                case 'newest':
                    filtered.sort((a,b) => (b.last_updated||'').localeCompare(a.last_updated||''));
                    break;
            }
            
            renderGrid();
        }
        
        // 渲染
        function renderGrid() {
            const grid = document.getElementById('grid');
            document.getElementById('stats').textContent = `${filtered.length} 件商品`;
            
            if (filtered.length === 0) {
                grid.innerHTML = '<div class="empty"><div class="empty-icon">🏔️</div>暂无商品</div>';
                return;
            }
            
            grid.innerHTML = filtered.map((p, i) => {
                const imgUrl = p.image_url || (p.local_image ? `../${p.local_image}` : '');
                const discount = p.discount_pct || 0;
                const symbol = p.symbol || '€';
                
                return `
                    <div class="card" onclick="showDetail(${i})">
                        <img class="card-img" src="${imgUrl}" alt="${p.model}" loading="lazy" 
                             onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 300 400%22><rect fill=%22%231a1a1a%22 width=%22300%22 height=%22400%22/><text fill=%22%23333%22 x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22>ARC</text></svg>'">
                        <div class="card-body">
                            <div class="card-name">${p.model || p.full_name || ''}</div>
                            <div class="card-price">
                                <span class="price-sale">${symbol}${p.sale_price}</span>
                                ${p.original_price ? `<span class="price-original">${symbol}${p.original_price}</span>` : ''}
                            </div>
                            <div class="card-tags">
                                ${discount >= 40 ? `<span class="tag">-${discount}%</span>` : ''}
                                <span class="tag tag-region">${p.region_name || ''}</span>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }
        
        // 详情
        function showDetail(idx) {
            const p = filtered[idx];
            const modal = document.getElementById('modal');
            const content = document.getElementById('modal-content');
            const imgUrl = p.image_url || (p.local_image ? `../${p.local_image}` : '');
            const symbol = p.symbol || '€';
            const discount = p.discount_pct || 0;
            
            const sizes = p.sizes || [];
            const sizeStock = p.size_stock || {};
            const colors = p.colors || [];
            
            content.innerHTML = `
                <img class="modal-img" src="${imgUrl}" alt="${p.model}"
                     onerror="this.style.background='#1a1a1a'">
                <div class="modal-body">
                    <div class="modal-title">${p.model || p.full_name || ''}</div>
                    <div class="modal-desc">${p.description || ''}</div>
                    
                    <div class="modal-prices">
                        <span class="modal-price-sale">${symbol}${p.sale_price}</span>
                        ${p.original_price ? `<span class="modal-price-original">${symbol}${p.original_price}</span>` : ''}
                        ${discount ? `<span class="modal-discount">-${discount}%</span>` : ''}
                    </div>
                    
                    ${sizes.length ? `
                        <div class="section-title">尺码</div>
                        <div class="size-grid">
                            ${sizes.map(s => {
                                const inStock = sizeStock[s] === 'in_stock';
                                return `<div class="size-item ${inStock ? 'in' : 'out'}">${s}</div>`;
                            }).join('')}
                        </div>
                    ` : ''}
                    
                    ${colors.length ? `
                        <div class="section-title">颜色</div>
                        <div class="color-grid">
                            ${colors.map(c => `<div class="color-item">${c}</div>`).join('')}
                        </div>
                    ` : ''}
                    
                    <a class="cta-btn" href="${p.url}" target="_blank" rel="noopener">
                        前往官方购买 →
                    </a>
                </div>
            `;
            
            modal.classList.add('show');
            document.body.style.overflow = 'hidden';
        }
        
        function closeModal() {
            document.getElementById('modal').classList.remove('show');
            document.body.style.overflow = '';
        }
        
        // 事件绑定
        document.getElementById('categories').addEventListener('click', e => {
            const tab = e.target.closest('.filter-tab');
            if (!tab) return;
            document.querySelectorAll('#categories .filter-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            currentCat = tab.dataset.cat;
            filterAndSort();
        });
        
        document.getElementById('regions').addEventListener('click', e => {
            const tab = e.target.closest('.filter-tab');
            if (!tab) return;
            document.querySelectorAll('#regions .filter-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            currentRegion = tab.dataset.region;
            filterAndSort();
        });
        
        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentSort = btn.dataset.sort;
                filterAndSort();
            });
        });
        
        // 点击遮罩关闭
        document.getElementById('modal').addEventListener('click', e => {
            if (e.target.id === 'modal') closeModal();
        });
        
        // 初始化
        filterAndSort();
    </script>
</body>
</html>
